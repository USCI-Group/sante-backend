# Santé Backend Environment Variables Template
# Copy this to .env and fill in the values

# General
ENV=production
ORIGIN=https://admin.sante.com.my
PORT=8081

# Database (External: 192.168.3.10)
DB_HOST=192.168.3.10
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=sante

# Security
JWT_SECRET_KEY=

# AWS - General & S3
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=sante-prod

# AWS - SES (Email)
AWS_SES_SENDER_EMAIL=
AWS_SES_ACCESS_KEY_ID=
AWS_SES_ACCESS_KEY=

# Firebase - Auth & Push Notifications
FIREBASE_PROJECT_ID=sante-mobile-app
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Other Integrations
SANTE_GOOGLE_AUTH_CLIENT_ID=
